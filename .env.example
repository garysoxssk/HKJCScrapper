# ============================================================================
# HKJCScrapper Environment Configuration
# ============================================================================
# Profiles: set APP_ENV to switch between configurations
#   APP_ENV=local  -> loads .env.local (local MongoDB)
#   APP_ENV=prod   -> loads .env.prod  (MongoDB Atlas)
#
# Copy this file to .env.local or .env.prod and fill in your values.
# ============================================================================

APP_ENV=local

# --- MongoDB (local) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=hkjc

# --- MongoDB (Atlas - for prod) ---
# When MONGODB_HOST is set, the URI is built from parts automatically:
#   mongodb+srv://MONGODB_USER:MONGODB_PASSWORD@MONGODB_HOST
# MONGODB_USER=garyso
# MONGODB_PASSWORD=<set via env var, never commit>
# MONGODB_HOST=scrapperdbcluster.twnkirh.mongodb.net

# --- HKJC API ---
GRAPHQL_ENDPOINT=https://info.cld.hkjc.com/graphql/base/

# --- Scheduler ---
DISCOVERY_INTERVAL_SECONDS=900

# --- Pagination ---
START_INDEX=1
END_INDEX=60

# --- Telegram notifications ---
TELEGRAM_ENABLED=false
TELEGRAM_APP_ID=0
TELEGRAM_API_KEY=
TELEGRAM_GROUP_ID=
TELEGRAM_SESSION_NAME=hkjc_scrapper_msg_bot
TELEGRAM_BOT_TOKEN=

# --- Timezone ---
# IANA timezone name for log timestamps and display (default: Asia/Hong_Kong)
APP_TIMEZONE=Asia/Hong_Kong

# --- Logging ---
LOG_LEVEL=INFO
