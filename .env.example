# MongoDB connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=hkjc

# HKJC API
GRAPHQL_ENDPOINT=https://info.cld.hkjc.com/graphql/base/

# Scheduler: how often to discover matches and evaluate rules (seconds)
DISCOVERY_INTERVAL_SECONDS=900

# Pagination
START_INDEX=1
END_INDEX=60

# Telegram notifications
# Set to true to enable Telegram notifications
TELEGRAM_ENABLED=false

# Get these from https://my.telegram.org/apps
TELEGRAM_APP_ID=0
TELEGRAM_API_KEY=

# Telegram group/channel ID
# Format: https://t.me/+XXXXXXXXXXX (must include https://)
# Or use numeric chat ID: -1001234567890
TELEGRAM_GROUP_ID=

# Session file name (will be created on first connection)
TELEGRAM_SESSION_NAME=hkjc_scrapper_msg_bot

# Telegram Bot Token ID
TELEGRAM_BOT_TOKEN=

# Logging
LOG_LEVEL=INFO
