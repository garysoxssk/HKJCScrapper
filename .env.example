# MongoDB connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=hkjc

# HKJC API
GRAPHQL_ENDPOINT=https://info.cld.hkjc.com/graphql/base/

# Polling interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# Odds types to capture (JSON array)
ODDS_TYPES=["HAD","HHA","HDC","HIL"]

# Pagination
START_INDEX=1
END_INDEX=60

# Logging
LOG_LEVEL=INFO
